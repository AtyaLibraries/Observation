<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Atya.Diagnostics.Observation</AssemblyName>
    <PackageId>Atya.Diagnostics.Observation</PackageId>
    <RootNamespace>Atya.Diagnostics.Observation</RootNamespace>
    <IsPackable>true</IsPackable>


    <MinVerTagPrefix>v</MinVerTagPrefix>
    <MinVerDefaultPreReleaseIdentifiers>alpha.0</MinVerDefaultPreReleaseIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

  <ItemGroup Label="Analyzers + versioning (build-only, not published)">
    <PackageReference Include="Atya.Governance.CodeQuality" PrivateAssets="all" />
    <PackageReference Include="MinVer" PrivateAssets="all" Condition="'$(RepositoryHasGitDirectory)' == 'true'" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="all" Condition="'$(RepositoryHasGitDirectory)' == 'true'" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Atya.Foundation.Guards" />
    <PackageReference Include="Atya.Diagnostics.Logging" />
    <PackageReference Include="Atya.Diagnostics.Metrics" />
    <PackageReference Include="Atya.Diagnostics.Tracing" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

</Project>
